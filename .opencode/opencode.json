{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "superpowers@git+https://github.com/obra/superpowers.git",
    "oh-my-openagent@git+https://github.com/code-yeongyu/oh-my-openagent.git"
  ],
  "mcp": {
    "gcloud": {
      "type": "local",
      "command": ["npx", "-y", "@google-cloud/gcloud-mcp"],
      "enabled": true
    },
    "grafana": {
      "type": "local",
      "command": ["mcp-grafana"],
      "enabled": true,
      "environment": {
        "GRAFANA_URL": "$GRAFANA_URL",
        "GRAFANA_SERVICE_ACCOUNT_TOKEN": "$GRAFANA_SERVICE_ACCOUNT_TOKEN"
      }
    },
    "kubernetes": {
      "type": "local",
      "command": ["npx", "-y", "kubernetes-mcp-server@latest", "--read-only"],
      "enabled": true
    },
    "nightingale": {
      "type": "local",
      "command": ["npx", "-y", "@n9e/n9e-mcp-server", "stdio"],
      "enabled": true,
      "environment": {
        "N9E_BASE_URL": "$N9E_BASE_URL",
        "N9E_TOKEN": "$N9E_TOKEN"
      }
    }
  }
}
